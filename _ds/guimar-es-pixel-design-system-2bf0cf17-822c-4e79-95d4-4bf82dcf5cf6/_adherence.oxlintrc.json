{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/agent/**",
              "components/core/**",
              "components/data/**",
              "components/mascot/**",
              "components/surface/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Press Start 2P|VT323|Silkscreen))/i]",
        "message": "Font not provided by the design system. Available: Press Start 2P, VT323, Silkscreen."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityReadout'] > JSXAttribute > JSXIdentifier[name!=/^(?:action|lines|elapsed|state|prompt|cursor|className|style|key|ref|className|style|children)$/]",
        "message": "<ActivityReadout> doesn't accept that prop. Declared props: action, lines, elapsed, state, prompt, cursor, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityReadout'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:working|learning|idle)$/]",
        "message": "<ActivityReadout> state must be one of 'working' | 'learning' | 'idle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|pulse|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, pulse, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|block|disabled|type|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, block, disabled, type, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|label|className|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, label, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|variant|size|disabled|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, label, variant, size, disabled, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|stage|evo|xp|xpMax|segments|className|style|key|ref|className|style|children)$/]",
        "message": "<LevelBadge> doesn't accept that prop. Declared props: level, stage, evo, xp, xpMax, segments, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|icon|tone|actions|footer|flat|inset|tight|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, icon, tone, actions, footer, flat, inset, tight, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PixelSprite'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|scale|frames|palette|shadow|glow|className|style|key|ref|className|style|children)$/]",
        "message": "<PixelSprite> doesn't accept that prop. Declared props: state, scale, frames, palette, shadow, glow, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|tone|variant|segments|height|label|showValue|valueText|className|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, tone, variant, segments, height, label, showValue, valueText, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:segments|solid)$/]",
        "message": "<ProgressBar> variant must be one of 'segments' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|name|state|level|maxLevel|progress|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<SkillNode> doesn't accept that prop. Declared props: icon, name, state, level, maxLevel, progress, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|value|unit|label|delta|tone|className|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: icon, value, unit, label, delta, tone, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|max|tone|segments|valueText|lowAt|className|style|key|ref|className|style|children)$/]",
        "message": "<StatBar> doesn't accept that prop. Declared props: icon, label, value, max, tone, segments, valueText, lowAt, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|tone|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, icon, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|level|skill|stat|mood)$/]",
        "message": "<TabItem> tone must be one of 'accent' | 'level' | 'skill' | 'stat' | 'mood'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|fill|className|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, tone, icon, fill, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|status|time|meta|right|onToggle|className|style|key|ref|className|style|children)$/]",
        "message": "<TaskItem> doesn't accept that prop. Declared props: title, status, time, meta, right, onToggle, className, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
